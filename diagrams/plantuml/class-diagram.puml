@startuml Collection_Tracker_Class_Diagram
!theme plain
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F0F0F0
skinparam classBorderColor #333333
skinparam arrowColor #333333

package "com.enrique.collectiontracker.book" {
  class Book extends BaseEntity {
    - title: String
    - author: String
    - isbn: String
    - publisher: String
    - publishedYear: Integer
    - genre: String
    - readStatus: ReadStatus
    - format: Format
    - notes: String
    --
    + getTitle(): String
    + setTitle(String): void
    + getAuthor(): String
    + setAuthor(String): void
    + getIsbn(): String
    + setIsbn(String): void
    + getGenre(): String
    + setGenre(String): void
    + getReadStatus(): ReadStatus
    + setReadStatus(ReadStatus): void
    + getFormat(): Format
    + setFormat(Format): void
  }

  interface BookRepository extends JpaRepository {
    + findByTitleContainingIgnoreCase(String): List<Book>
    + findByGenreIgnoreCase(String): List<Book>
    + findByReadStatus(ReadStatus): List<Book>
    + findByFormat(Format): List<Book>
    + existsByIsbnAndTitleIgnoreCase(String, String): boolean
  }

  class BookService {
    - bookRepository: BookRepository
    --
    + findAll(): List<Book>
    + findById(Long): Optional<Book>
    + save(Book): Book
    + deleteById(Long): void
    + searchByTitle(String): List<Book>
    + filter(String, ReadStatus, Format): List<Book>
    + existsById(Long): boolean
  }

  class BookController {
    - bookService: BookService
    --
    + getAllBooks(): List<Book>
    + getBookById(Long): Book
    + createBook(Book): ResponseEntity<Book>
    + updateBook(Long, Book): Book
    + deleteBook(Long): ResponseEntity<Void>
    + searchBooks(String): List<Book>
    + filterBooks(String, ReadStatus, Format): List<Book>
  }

  class BookViewController {
    - bookService: BookService
    --
    + list(Model): String
    + newForm(Model): String
    + create(Book, BindingResult, Model): String
    + detail(Long, Model): String
    + editForm(Long, Model): String
    + update(Long, Book, BindingResult, Model): String
    + delete(Long): String
  }

  class BookSpecifications {
    {static} + hasGenre(String): Specification<Book>
    {static} + hasStatus(ReadStatus): Specification<Book>
    {static} + hasFormat(Format): Specification<Book>
  }

  BookRepository --> BookService
  BookService --> BookSpecifications
  BookController --> BookService
  BookViewController --> BookService
  Book --> ReadStatus
  Book --> Format
}

