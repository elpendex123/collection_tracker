package "com.enrique.collectiontracker.common" {
  abstract class BaseEntity {
    # id: Long
    # createdAt: LocalDateTime
    # updatedAt: LocalDateTime
    --
    # onCreate(): void
    # onUpdate(): void
    + getId(): Long
    + setId(Long): void
    + getCreatedAt(): LocalDateTime
    + getUpdatedAt(): LocalDateTime
  }

  enum ReadStatus {
    UNREAD
    IN_PROGRESS
    READ
  }

  enum CompletionStatus {
    BACKLOG
    PLAYING
    BEATEN
    DROPPED
  }

  enum Format {
    PHYSICAL
    DIGITAL
  }

  class ResourceNotFoundException extends Exception {
    + ResourceNotFoundException(String)
  }

  class GlobalExceptionHandler {
    + handleResourceNotFound(ResourceNotFoundException): ResponseEntity<ErrorResponse>
    + handleValidationException(MethodArgumentNotValidException): ResponseEntity<ErrorResponse>
  }

  class HomeController {
    - bookService: BookService
    - comicService: ComicService
    - videoGameService: VideoGameService
    --
    + home(Model): String
  }
}

package "org.springframework.data.jpa.repository" {
  interface JpaRepository<T, ID> {
    + save(T): T
    + saveAll(Iterable<T>): List<T>
    + findById(ID): Optional<T>
    + findAll(): List<T>
    + delete(T): void
    + deleteById(ID): void
  }

  interface JpaSpecificationExecutor<T> {
    + findAll(Specification<T>): List<T>
  }
}

note right of BaseEntity
  Abstract base class for all entities
  Automatically manages timestamps
  Uses @PrePersist and @PreUpdate
end note

note right of BookService
  Service layer handles business logic
  Delegates to repository for data access
  Performs validation before save
end note

note right of BookController
  REST API endpoints
  Maps HTTP requests to service methods
  Returns JSON responses
end note

note right of BookViewController
  Thymeleaf template controller
  Maps requests to HTML views
  Handles form submissions
end note

@enduml
